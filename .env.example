# Environment Variables Configuration

# Application
APP_NAME=UPI Secure Pay AI
APP_VERSION=1.0.0
DEBUG=False
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/upi_secure_pay
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/upi_secure_pay

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW_TRANSACTIONS=upi.transactions.raw
KAFKA_TOPIC_SCORED=upi.transactions.scored
KAFKA_TOPIC_ALERTS=upi.alerts
KAFKA_CONSUMER_GROUP=fraud-processor

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ML Models
LIGHTGBM_MODEL_PATH=models/lightgbm/fraud_model.txt
TRANSFORMER_MODEL_PATH=models/transformer/fraud_transformer
ENSEMBLE_WEIGHT_LIGHTGBM=0.5
ENSEMBLE_WEIGHT_TRANSFORMER=0.5

# Fraud Detection Thresholds
FRAUD_THRESHOLD_BLOCK=85
FRAUD_THRESHOLD_REVIEW=60

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
